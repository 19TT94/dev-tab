VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_BUSINESS_NAME=Your Name LLC
VITE_BUSINESS_EMAIL=you@example.com
VITE_BUSINESS_PHONE=555.555.5555
VITE_BUSINESS_WEBSITE=www.example.com
VITE_BUSINESS_ADDRESS=123 Main St, City, ST 12345
# Optional: override default bundled logo (path under public/ or full URL)
# VITE_BUSINESS_LOGO=/custom-logo.png

# Set to true to run without Supabase (uses local mock data in the browser)
VITE_USE_MOCK_DATA=false

# First invoice sequence number for each year (e.g. 100 -> INV-2026-100)
VITE_INVOICE_NUMBER_START=1
